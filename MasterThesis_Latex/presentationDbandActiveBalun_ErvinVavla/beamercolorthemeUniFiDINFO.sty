\mode<presentation>

\definecolor{UniFidarkblue}{RGB}{0, 48, 83}
\definecolor{UniFiblue}{RGB}{12, 71, 123}
\definecolor{UniFigray}{RGB}{233, 233, 233}
\definecolor{UniFitextblue}{RGB}{55, 96, 146}

\setbeamercolor{title}{fg = UniFitextblue}
\setbeamercolor{subtitle}{fg = black}
\setbeamercolor{date}{fg = white, bg = UniFiblue}

\setbeamercolor{section in toc}{fg = UniFitextblue}
\setbeamercolor{section in toc shaded}{fg = UniFitextblue}


\setbeamercolor{title in head/foot}{fg = white, bg = UniFiblue}
\setbeamercolor{date in head/foot}{fg = white}
\setbeamercolor{frametitle}{fg = UniFitextblue}
\setbeamercolor{normal text}{fg = black}
\setbeamercolor{block title}{bg = UniFitextblue!20!bg}
\setbeamercolor{block body}{bg = UniFitextblue!10!bg}
\setbeamercolor{alerted text}{fg = red}
\setbeamercolor{block title alerted}{bg = red!20!bg}
\setbeamercolor{block body alerted}{bg = red!10!bg}
\setbeamercolor{example text}{fg = UniFitextblue}
\setbeamercolor{block title example}{fg = UniFiblue, bg = UniFigray!90!black}
\setbeamercolor{block body example}{bg = UniFigray}
\setbeamercolor{item}{fg = UniFiblue}
\setbeamercolor{subitem}{fg = UniFiblue}
\setbeamercolor{subsubitem}{fg = UniFiblue}
\setbeamercolor{description item}{fg = UniFitextblue}
\setbeamercolor{caption name}{fg = UniFitextblue}
\setbeamercolor{caption}{fg = black}
\setbeamercolor{page number in head/foot}{fg = white, bg = UniFidarkblue}

\mode
<all>
